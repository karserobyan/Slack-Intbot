# ── Slack ────────────────────────────────────────────────────────────────────
# Bot token (xoxb-...) — from your Slack App's "OAuth & Permissions" page
SLACK_BOT_TOKEN=xoxb-your-token-here

# Signing secret — from your Slack App's "Basic Information" page
SLACK_SIGNING_SECRET=your-signing-secret-here

# App-level token (xapp-...) — required for Socket Mode only
# Generate under "Basic Information" > "App-Level Tokens" with connections:write scope
# Leave blank to use HTTP mode instead
SLACK_APP_TOKEN=xapp-your-app-token-here

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── MCP Tokens ───────────────────────────────────────────────────────────────
# Slack MCP — token used to authenticate to https://mcp.slack.com/mcp
# Can reuse SLACK_BOT_TOKEN (the bot will fall back to it automatically)
# SLACK_MCP_TOKEN=xoxb-your-token-here

# Atlassian REST API — used for Confluence and Jira search (Basic Auth)
# ATLASSIAN_EMAIL: your Atlassian account email
# ATLASSIAN_API_TOKEN: API token from https://id.atlassian.com/manage-profile/security/api-tokens
# ATLASSIAN_BASE_URL: optional override (default: https://servicetitan.atlassian.net)
ATLASSIAN_EMAIL=you@company.atlassian.net
ATLASSIAN_API_TOKEN=your-atlassian-api-token-here
# ATLASSIAN_BASE_URL=https://yourorg.atlassian.net

# ── Knowledge Base ────────────────────────────────────────────────────────────
# KB search uses Anthropic's web_search tool scoped to help.servicetitan.com.
# No extra config needed — it reuses ANTHROPIC_API_KEY above.

# ── Optional ─────────────────────────────────────────────────────────────────
# HTTP port when running in HTTP mode (default: 3000)
# PORT=3000

# Response cache TTL in milliseconds (default: 3600000 = 1 hour)
# CACHE_TTL_MS=3600000

# Minimum query duration (ms) before a response gets cached. Skips caching for
# trivial fast-path responses. (Default: 30000 = 30s)
# CACHE_MIN_MS=30000

# Minimum query duration (ms) before a response is eligible for auto-save into
# knowledge.md as a [kb, ...] entry. (Default: 30000 = 30s)
# KNOWLEDGE_MIN_MS=30000

# Per-thread conversation history retention. (Default: 14400000 = 4 hours)
# CONVERSATION_TTL_MS=14400000

# Log level: info | debug
# LOG_LEVEL=info

# ── Feedback / nomination review channel ─────────────────────────────────────
# Channel ID where Wrong-Answer review cards and bot-response nomination cards
# are posted. The bot must be a member. Create a private channel for moderators
# and paste its ID here.
#
# Canonical name: FEEDBACK_REVIEW_CHANNEL_ID. Two legacy aliases (FEEDBACK_CHANNEL,
# FEEDBACK_CHANNEL_ID) are also honored for backwards compatibility — set any one.
FEEDBACK_REVIEW_CHANNEL_ID=
# FEEDBACK_CHANNEL=        # legacy alias — same effect
# FEEDBACK_CHANNEL_ID=     # legacy alias — same effect

# Claude model override — defaults to claude-sonnet-4-6
# Useful for switching to a cheaper model during development/testing
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Claude API timeout in milliseconds (default: 90000 = 90 seconds)
# Increase if you see frequent timeout errors with complex queries
# CLAUDE_TIMEOUT_MS=90000

# Rate limiting — max queries per user per window (default: 5 per minute)
# RATE_LIMIT_MAX=5
# RATE_LIMIT_WINDOW_MS=60000

# ── Pipeline kill-switch ─────────────────────────────────────────────────────
# The four-stage query pipeline (Interpreter → Search → Evaluator → Answerer) is
# now the DEFAULT. Leave this unset to use it. Set to "false" ONLY to roll back
# to the legacy single-call path without a redeploy. Any other value = new pipeline.
# NEW_PIPELINE=false
