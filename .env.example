# ── Slack ────────────────────────────────────────────────────────────────────
# Bot token (xoxb-...) — from your Slack App's "OAuth & Permissions" page
SLACK_BOT_TOKEN=xoxb-your-token-here

# Signing secret — from your Slack App's "Basic Information" page
SLACK_SIGNING_SECRET=your-signing-secret-here

# App-level token (xapp-...) — required for Socket Mode only
# Generate under "Basic Information" > "App-Level Tokens" with connections:write scope
# Leave blank to use HTTP mode instead
SLACK_APP_TOKEN=xapp-your-app-token-here

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── MCP Tokens ───────────────────────────────────────────────────────────────
# Slack MCP — token used to authenticate to https://mcp.slack.com/mcp
# Can reuse SLACK_BOT_TOKEN (the bot will fall back to it automatically)
# SLACK_MCP_TOKEN=xoxb-your-token-here

# Atlassian REST API — used for Confluence and Jira search (Basic Auth)
# ATLASSIAN_EMAIL: your Atlassian account email
# ATLASSIAN_API_TOKEN: API token from https://id.atlassian.com/manage-profile/security/api-tokens
# ATLASSIAN_BASE_URL: optional override (default: https://servicetitan.atlassian.net)
ATLASSIAN_EMAIL=you@company.atlassian.net
ATLASSIAN_API_TOKEN=your-atlassian-api-token-here
# ATLASSIAN_BASE_URL=https://yourorg.atlassian.net

# ── Google Custom Search ──────────────────────────────────────────────────────
# Google Custom Search — for Knowledge Base (help.servicetitan.com) search
# Create a CSE at https://cse.google.com, scoped to help.servicetitan.com
GOOGLE_CSE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_cse_id_here

# ── Optional ─────────────────────────────────────────────────────────────────
# HTTP port when running in HTTP mode (default: 3000)
# PORT=3000

# Cache TTL in milliseconds (default: 3600000 = 1 hour)
# CACHE_TTL_MS=3600000

# Log level: info | debug
# LOG_LEVEL=info

# Slack channel ID for feedback moderation (Approve/Reject review workflow)
# Create a private channel, add the bot and your reviewers, then paste the channel ID here
# FEEDBACK_CHANNEL_ID is retired — replaced by FEEDBACK_REVIEW_CHANNEL_ID
FEEDBACK_REVIEW_CHANNEL_ID=

# Internal alias used by knowledge-writer.js and nominations.js for KB auto-save
# alerts and nomination cards. Defaults to FEEDBACK_REVIEW_CHANNEL_ID if not set.
# FEEDBACK_CHANNEL=

# Claude model override — defaults to claude-sonnet-4-20250514
# Useful for switching to a cheaper model during development/testing
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Claude API timeout in milliseconds (default: 90000 = 90 seconds)
# Increase if you see frequent timeout errors with complex queries
# CLAUDE_TIMEOUT_MS=90000

# Rate limiting — max queries per user per window (default: 5 per minute)
# RATE_LIMIT_MAX=5
# RATE_LIMIT_WINDOW_MS=60000
